# ============================================================
# ORI-CRUIT — Root Environment Variables
# ============================================================

# ── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/oricruit"

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# ── App ─────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
APP_BASE_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3000"

# ── WhatsApp Business Cloud API ─────────────────────────────
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_API_VERSION="v18.0"

# ── HRappka Integration ─────────────────────────────────────
HRAPPKA_API_KEY=""
HRAPPKA_API_URL="https://api.hrappka.pl/v1"
HRAPPKA_ENABLED="false"

# ── Email Provider (Resend / SMTP) ──────────────────────────
EMAIL_PROVIDER="resend"  # "resend" | "smtp"
RESEND_API_KEY=""
EMAIL_FROM="noreply@ori-cruit.com"

# ── Storage (S3-compatible) ──────────────────────────────────
STORAGE_PROVIDER="local"  # "local" | "s3"
S3_BUCKET=""
S3_REGION="eu-central-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""  # For Cloudflare R2 or custom

# ── Google Calendar Integration ──────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"

# ── Redis (for queue / rate-limiting) ────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=""
